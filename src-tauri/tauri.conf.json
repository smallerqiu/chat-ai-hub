{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chat AI Hub",
  "version": "0.1.0",
  "identifier": "com.suomier.chat-ai-hub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chat AI Hub",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 620,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
